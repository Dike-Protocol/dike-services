NODE_ENV=development
PORT=4000

STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

DIKE_CONTRACTS_ROOT=/Users/sachplayz/Projects/Dike_Stellar/dike-contracts
DIKE_MANIFEST_PATH=./deployments/testnet.json

DATABASE_URL=postgres://postgres:postgres@localhost:5432/dike_services
REDIS_URL=redis://localhost:6379

# Required for the first run against an empty DB. Use a retained deployment ledger.
# 3383250 = just before the 2026-07-01 testnet redeploy (11 new contract IDs).
INDEXER_START_LEDGER=3383250
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LEDGER_WINDOW=250
RECONCILIATION_INTERVAL_MS=60000
INDEXER_LAG_ALERT_THRESHOLD=50
